<?xml version="1.0" encoding="utf-8"?>
<ExtensionManifest Version="7.0" ExtensionBundleId="com.otool.oline" ExtensionBundleVersion="1.0.0" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance">
    <ExtensionList>
        <Extension Id="com.otool.oline.panel" Version="1.0.0" />
    </ExtensionList>
    <ExecutionEnvironment>
        <HostList>
            <Host Name="ILST" Version="[25.0,99.9]" />
        </HostList>
        <LocaleList>
            <Locale Code="All" />
        </LocaleList>
        <RequiredRuntimeList>
            <RequiredRuntime Name="CSXS" Version="7.0" />
        </RequiredRuntimeList>
    </ExecutionEnvironment>
    <DispatchInfoList>
        <Extension Id="com.otool.oline.panel">
            <DispatchInfo>
                <Resources>
                    <MainPath>./index.html</MainPath>
                    <ScriptPath>./host/index.jsx</ScriptPath>
                </Resources>
                <Lifecycle>
                    <AutoVisible>true</AutoVisible>
                </Lifecycle>
                <UI>
                    <Type>Panel</Type>
                    <Menu>O'Line</Menu>
                    <Geometry>
                        <Size>
                            <Width>340</Width>
                            <Height>640</Height>
                        </Size>
                        <MinSize>
                            <Width>300</Width>
                            <Height>500</Height>
                        </MinSize>
                        <MaxSize>
                            <Width>1280</Width>
                            <Height>1600</Height>
                        </MaxSize>
                    </Geometry>
                    <Icons>
                        <Icon Type="Normal">./icons/IconLight.png</Icon>
                        <Icon Type="RollOver">./icons/IconLight.png</Icon>
                        <Icon Type="Disabled">./icons/IconLight.png</Icon>
                        <Icon Type="DarkNormal">./icons/IconDark.png</Icon>
                        <Icon Type="DarkRollOver">./icons/IconDark.png</Icon>
                    </Icons>
                </UI>
            </DispatchInfo>
        </Extension>
    </DispatchInfoList>
</ExtensionManifest>
